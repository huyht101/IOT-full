      "item": [
        {
          "name": "Get Dashboard",
          "request": {
            "method": "GET",
            "header": [],
            "description": "Load the current dashboard snapshot, including current device state, sensor state, chart points, and last_ts.",
            "url": {
              "raw": "{{baseUrl}}/api/v1/dashboard",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "dashboard"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Dashboard Realtime",
          "request": {
            "method": "GET",
            "header": [],
            "description": "Poll dashboard deltas using the previous dashboard last_ts value.",
            "url": {
              "raw": "{{baseUrl}}/api/v1/dashboard/realtime?since={{since}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
