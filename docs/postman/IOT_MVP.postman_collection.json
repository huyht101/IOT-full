                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Devices",
      "item": [
        {
          "name": "Toggle Device",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Send a manual on/off command to a device and wait for publish plus ACK finalization.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"on\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/devices/{{deviceId}}/toggle",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "devices",
                "{{deviceId}}",
                "toggle"
              ]
            }
          },
          "response": []
        }
      ]
    },
